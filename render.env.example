# ============================================
# Render Environment Variables
# ============================================
# Set these in Render Dashboard > Environment Groups

# --- Group: ct550 (Backend Web Service) ---
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/ct550?retryWrites=true&w=majority
JWT_SECRET=your-strong-random-secret-here
NODE_ENV=production
FRONTEND_URL=https://ct550-frontend.onrender.com
CORS_ORIGIN=https://ct550-frontend.onrender.com
# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=https://ct550.onrender.com/api/auth/google/callback
# Optional vars
# MAX_UPLOAD_FILE_SIZE_MB=10
# AI_DETECTION_THRESHOLD=70

# --- Group: ct550-frontend (Frontend Static Site) ---
VITE_API_BASE_URL=https://ct550.onrender.com/api
