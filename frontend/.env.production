VITE_API_BASE_URL=https://ct550.onrender.com/api
VITE_UPLOADS_BASE_URL=https://ct550.onrender.com
# When set, the frontend calls the book-service microservice directly,
# bypassing the main-backend proxy. This prevents 504 hangs that the
# main-backend proxy can exhibit when forwarding protected POST requests.
VITE_BOOK_SERVICE_URL=https://ct550-bookservice.onrender.com
