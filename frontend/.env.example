VITE_API_BASE_URL=http://127.0.0.1:5000/api
VITE_UPLOADS_BASE_URL=http://127.0.0.1:5000
# Optional: when set, the frontend calls the book-service microservice
# directly instead of going through the main-backend proxy. Useful in
# production where the proxy occasionally hangs on protected POSTs.
# Example: VITE_BOOK_SERVICE_URL=http://127.0.0.1:5001
