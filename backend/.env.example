# Server port
# Default: 5000
PORT=5000

# MongoDB Atlas connection string (required)
# Example: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/ct550?retryWrites=true&w=majority

# JWT signing secret (required)
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-strong-random-secret-here

# CORS allowed origins (optional)
# Comma-separated list of allowed origins. Defaults to localhost dev origins when NODE_ENV is not production.
# Example: https://frontend.onrender.com,https://custom-domain.com
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Max upload file size in MB (optional)
# Default: 10
MAX_UPLOAD_FILE_SIZE_MB=10

# AI detection threshold in percentage (optional)
# Value 0-100. Default: 70
AI_DETECTION_THRESHOLD=70

# Google OAuth Client ID (optional — required if using Google OAuth)
# Obtain from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=

# Google OAuth Client Secret (optional — required if using Google OAuth)
GOOGLE_CLIENT_SECRET=

# Google OAuth callback URL (optional) — set to the backend callback URL used for OAuth flows.
# Example (development): http://localhost:5000/api/auth/google/callback
# Example (production): https://ct550.onrender.com/api/auth/google/callback
GOOGLE_CALLBACK_URL=

# Frontend URL (optional)
# Used for CORS and OAuth redirects. Default: http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Facebook OAuth Client ID (optional — required if using Facebook OAuth)
# Obtain from Facebook Developers > Your App > Dashboard > App ID
FACEBOOK_CLIENT_ID=

# Facebook OAuth Client Secret (optional — required if using Facebook OAuth)
FACEBOOK_CLIENT_SECRET=

# Facebook OAuth callback URL (optional)
# Example (development): http://localhost:5000/api/auth/facebook/callback
# Example (production): https://ct550.onrender.com/api/auth/facebook/callback
FACEBOOK_CALLBACK_URL=

# ========================================
# Auto-Tagging Configuration
# ========================================

# Google Cloud Vision API Key (optional — required for Google Vision provider)
# Create API key at: https://console.cloud.google.com/apis/credentials
# Requires Cloud Vision API enabled and billing enabled (free tier: 1000 images/month)
GOOGLE_VISION_API_KEY=

# Auto-tag provider (optional)
# 'google-vision' → uses Google Cloud Vision API
# 'huggingface' → uses HuggingFace Inference API (default)
AUTO_TAG_PROVIDER=huggingface

# Google Vision label confidence threshold (optional)
# Float 0-1. Labels below this score are discarded. Default: 0.6
GOOGLE_VISION_CONFIDENCE=0.6

# HuggingFace model for auto-tagging (optional — only used when AUTO_TAG_PROVIDER=huggingface)
# Default: google/vit-base-patch16-224 (ImageNet classification)
AUTO_TAG_MODEL=google/vit-base-patch16-224

# HuggingFace classification confidence threshold (optional — only used when AUTO_TAG_PROVIDER=huggingface)
# Float 0-1. Predictions below this score are discarded. Default: 0.2
AUTO_TAG_CONFIDENCE=0.2

# Max number of tags to generate from any provider (optional)
# Default: 10
AUTO_TAG_MAX_TAGS=10
