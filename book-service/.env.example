# Server port
# Default: 5001
PORT=5001

# MongoDB Atlas connection string (required)
# Must point to the SAME database as the main IlluWrl backend
# (the book-service shares the `users` collection and stores its own
# data in prefixed collections: book_books, book_orders, book_carts,
# book_sellerprofiles).
# Example: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/CT550?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/CT550?retryWrites=true&w=majority

# JWT signing secret (required)
# Must match the IlluWrl backend JWT_SECRET for shared auth
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-strong-random-secret-here

# CORS allowed origins (optional)
# Comma-separated list. Defaults to localhost dev origins when NODE_ENV is not production.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Stripe secret key (optional — required for payment processing)
# Obtain from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook secret (optional — required for webhook verification)
# Obtain from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudinary configuration (optional — required for book cover uploads)
# Obtain from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend URL (optional)
# Used for CORS allowlisting and Stripe redirect/success/cancel URLs.
# Example (development): http://localhost:5173
# Example (production): https://ct550-frontend.onrender.com
# Default: http://localhost:5173
FRONTEND_URL=http://localhost:5173
